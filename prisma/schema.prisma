// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  correo    String   @unique
  password  String
  rol       Rol      @default(ADMIN)
  createdAt DateTime @default(now())
}

model Ruta {
  id        Int      @id @default(autoincrement())
  origen    String
  destino   String
  estado    String   @default("Activa")
  createdAt DateTime @default(now())

  horarios  Horario[]
  barrios   Barrio[]
  vehiculos Vehiculo[]
}

model Horario {
  id        Int      @id @default(autoincrement())
  dia       String
  hora      String

  rutaId    Int
  ruta      Ruta @relation(fields: [rutaId], references: [id])
}

model Barrio {
  id        Int      @id @default(autoincrement())
  nombre    String

  rutaId    Int
  ruta      Ruta @relation(fields: [rutaId], references: [id])
}

model Queja {
  id                  Int      @id @default(autoincrement())
  nombre              String
  correo              String?
  telefono            String?
  titulo              String
  descripcion         String
  estado              String   @default("Pendiente")
  codigoSeguimiento   String   @unique
  createdAt           DateTime @default(now())

  respuestas          Respuesta[]
}

model Respuesta {
  id        Int      @id @default(autoincrement())
  mensaje   String
  createdAt DateTime @default(now())

  quejaId   Int
  queja     Queja @relation(fields: [quejaId], references: [id])
}

model Vehiculo {
  id          Int      @id @default(autoincrement())
  placa       String   @unique
  tipo        String
  conductor   String
  capacidad   String?
  estado      String   @default("Disponible")
  createdAt   DateTime @default(now())

  rutaId      Int?
  ruta        Ruta? @relation(fields: [rutaId], references: [id])
}